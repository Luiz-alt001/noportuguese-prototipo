{
  "version": 2,
  "rewrites": [
    { "source": "/aluno",           "destination": "/aluno/index.html" },
    { "source": "/aluno/((?!.*\\.html$).*)", "destination": "/aluno/index.html" },
    { "source": "/professor",       "destination": "/professor/index.html" },
    { "source": "/professor/((?!.*\\.html$).*)", "destination": "/professor/index.html" },
    { "source": "/admin",           "destination": "/admin/index.html" },
    { "source": "/admin/((?!.*\\.html$).*)", "destination": "/admin/index.html" },
    { "source": "/((?!api|aluno|professor|admin|_vercel).*)", "destination": "/public/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "https://noportuguese.vercel.app" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Authorization, Content-Type" }
      ]
    }
  ],
  "functions": {
    "api/**/*.js": {
      "memory": 128,
      "maxDuration": 10
    }
  }
}
