# =================================================================
# VARIÁVEIS DE AMBIENTE — NUNCA SUBA ESTE ARQUIVO AO GIT
# Copie como .env.local e preencha com seus valores reais
# =================================================================

# --- Supabase ---
# Encontre em: supabase.com → seu projeto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- MercadoPago ---
# Encontre em: mercadopago.com.br/developers → Suas aplicações → Credenciais
# Use TEST- para sandbox, APP- para produção
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000
MP_WEBHOOK_SECRET=sua_chave_secreta_webhook

# --- App ---
# URL pública do projeto na Vercel (atualizar após o primeiro deploy)
APP_URL=https://noportuguese.vercel.app

# --- E-mail (para envio de boas-vindas) ---
# Recomendado: Resend (resend.com) — plano grátis suficiente para o protótipo
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@noportuguese.com.br
